# WordPress GraphQL API endpoint
# Development: Use your local WordPress or dev environment
# Production: Set via Terminus Secrets Manager per environment
WORDPRESS_API_URL=https://dev-your-wp-site.pantheonsite.io/graphql

# Revalidation secret for on-demand cache invalidation
# Generate a secure random string and use the same value in WordPress
WORDPRESS_REVALIDATE_SECRET=your-secure-random-string-here

# Cache debugging (optional)
# Set to "true" or "1" to enable verbose cache handler logging
# CACHE_DEBUG=true

# The following variables are automatically set by Pantheon in production:
# CACHE_BUCKET - GCS bucket name for cache storage
# OUTBOUND_PROXY_ENDPOINT - Edge cache proxy endpoint
